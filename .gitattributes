# Cross-platform text handling
* text=auto
*.py text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.bat text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.npy binary
*.npz binary
*.zip binary
*.tar.gz binary
*.whl binary
*.ttf binary
*.otf binary

# LFS for large JSON
"data/dwg_samples/output/hotel-ground-floor-plan.json" filter=lfs diff=lfs merge=lfs -text
